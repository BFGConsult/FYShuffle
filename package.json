{
  "name": "fyshuffle",
  "version": "0.0.9",
  "type": "module",
  "main": "./dist/FYShuffle.node.js",
  "module": "./dist/FYShuffle.module.js",
  "browser": "./dist/FYShuffle.js",
  "types": "./dist/FYShuffle.d.ts",
  "exports": {
    "import": {
      "types": "./dist/FYShuffle.d.ts",
      "default": "./dist/FYShuffle.module.js"
    },
    "require": {
      "types": "./dist/FYShuffle.d.ts",
      "default": "./dist/FYShuffle.node.js"
    }
  },
  "scripts": {
      "tsgen": "tsc -p tsconfig.build.json",
      "types": "dts-bundle-generator --project tsconfig.dts.json -o dist/FYShuffle.d.ts ts/FYShuffle.module.d.ts",
      "build": "node scripts/build.js && npm run tsgen && npm run types"
  },
  "devDependencies": {
    "@types/node": "^20.8.10",
    "dts-bundle-generator": "^9.5.1",
    "prettier": "^3.6.2",
    "terser": "^5.43.1",
    "typescript": "^5.8.3",
    "undici-types": "^7.11.0"
  }
}
