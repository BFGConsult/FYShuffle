{
  "compilerOptions": {
    "target": "ES2017",
    "module": "nodenext",
    "lib": ["es2015", "DOM"],
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": "./ts",
    "strict": true
  },
  "include": [
    "dist/FYShuffle.js",
    "dist/FYShuffle.module.js",
    "dist/FYShuffle.node.js"
  ]
}
